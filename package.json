{
  "name": "metraly-website",
  "version": "0.1.0-alpha",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "npm run lint:claims && npm run lint:code",
    "lint:claims": "node scripts/check-forbidden-claims.mjs",
    "lint:code": "eslint .",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "smoke:e2e": "npx --yes --package=@playwright/test@1.57.0 playwright test",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "ci": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.0.7",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.48.1"
  }
}
